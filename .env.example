# ============================================================
# Environment Variables — cc-kelompok-freepalestine
# Copy this file to .env and fill in your values.
# NEVER commit real secrets to version control.
# ============================================================

# ==================== GENERAL ====================
NODE_ENV=development
COMPOSE_PROJECT_NAME=cc-freepalestine

# ==================== AUTH SERVICE (Port 8001) ====================
AUTH_DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/auth_db
SECRET_KEY=change-this-to-a-random-string-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==================== DASHBOARD SERVICE (Port 8002) ====================
DASHBOARD_DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/dashboard_db
AUTH_SERVICE_URL=http://localhost:8001

# ==================== DATABASE (PostgreSQL) ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=auth_db
DB_PORT=5432

# ==================== FRONTEND ====================
VITE_API_BASE_URL=http://localhost:8000/api
FRONTEND_PORT=5173

# ==================== CORS / ALLOWED ORIGINS ====================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== DOCKER PORT MAPPING ====================
BACKEND_PORT=8000
GATEWAY_PORT=80
