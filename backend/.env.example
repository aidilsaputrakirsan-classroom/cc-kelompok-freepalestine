# ============================================================
# Backend Environment Variables
# ============================================================
# Copy file ini menjadi .env dan sesuaikan nilainya
# cp .env.example .env

# Database
# Untuk development lokal (tanpa Docker):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cloudapp
# Untuk Docker container (gunakan host.docker.internal):
# DATABASE_URL=postgresql://postgres:yourpassword@host.docker.internal:5432/cloudapp

# JWT Authentication
SECRET_KEY=your-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — daftar origin yang diizinkan (pisahkan dengan koma)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
