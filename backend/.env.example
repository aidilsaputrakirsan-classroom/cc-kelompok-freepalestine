# ============================================================
# Dashboard Telkom TREG 4 Kalimantan — Backend env (template)
#
# Cara pakai:
#   1. Copy file ini menjadi `.env`
#   2. Ganti nilai sesuai lingkungan Anda.
#   3. `.env` asli TIDAK boleh di-commit (sudah ada di .gitignore).
# ============================================================


# ---------------- DATABASE ----------------
# Mode 1 — Development manual di laptop (PostgreSQL terinstal native):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/telkom_dashboard

# Mode 2 — Container backend → PostgreSQL di host (Docker Desktop
# Windows/Mac, modul 5). `host.docker.internal` adalah DNS spesial
# yang disediakan Docker untuk menunjuk mesin host.
# DATABASE_URL=postgresql://postgres:yourpassword@host.docker.internal:5432/telkom_dashboard

# Mode 3 — Docker Compose (modul 6 & 7). "db" adalah nama service
# PostgreSQL di docker-compose.yml yang berada di network yang sama.
# DATABASE_URL=postgresql://postgres:yourpassword@db:5432/telkom_dashboard


# ---------------- JWT AUTH ----------------
# Generate secret kuat dengan:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-minimum-32-characters-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ---------------- CORS ----------------
# Whitelist origin yang boleh memanggil API (pisahkan dengan koma).
# JANGAN pakai "*" untuk production.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


# ---------------- WAIT-FOR-DB (opsional) ----------------
# Dibaca oleh scripts/wait-for-db.sh saat container start.
# Nilai default sudah aman untuk docker compose, ganti kalau perlu.
# DB_HOST=db
# DB_PORT=5432
# DB_USER=postgres
# DB_MAX_WAIT=60
