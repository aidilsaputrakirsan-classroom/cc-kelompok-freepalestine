# ============================================================
# Docker Ignore — Backend
# ============================================================
# File/folder yang TIDAK perlu masuk ke Docker image
# Tujuan: keamanan (.env), ukuran (cache), kecepatan build

# Secrets & local env (JANGAN masuk ke image!)
.env
.env.*

# Python cache & bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/

# Virtual environment
venv/
.venv/
env/

# Git & IDE
.git/
.gitignore
.idea/
.vscode/

# Testing
tests/
*.test.py
.pytest_cache/
.coverage
htmlcov/

# Documentation (tidak diperlukan di runtime)
*.md
docs/

# Docker files sendiri
Dockerfile
.dockerignore
