# ============================================================
# Dashboard Telkom TREG 4 Kalimantan — Frontend env (template)
#
# Vite mengharuskan setiap variabel env diawali prefix VITE_ agar
# terekspos ke kode React lewat import.meta.env.*.
# Nilai akan di-embed saat `npm run build`, jadi pastikan sudah
# benar SEBELUM build image Docker.
#
# Cara pakai:
#   1. Copy file ini menjadi `.env`  (atau `.env.local`)
#   2. Sesuaikan nilai di bawah.
#   3. `npm run dev` atau `npm run build` akan otomatis membacanya.
# ============================================================

# URL backend FastAPI yang akan dipanggil frontend.
# - Mode development manual (laptop):
VITE_API_URL=http://localhost:8000

# - Mode docker compose (service name "backend" di network cloudnet):
#   VITE_API_URL=http://backend:8000
#
# - Mode production (setelah deploy):
#   VITE_API_URL=https://api.dashboard-telkom.example.com
